PORT=5000
NODE_ENV=development

# Database configuration
MONGODB_URI=mongodb://localhost:27017/nigehbaan

# Redis configuration (Used for rate limits, socket adapter, SOS caching)
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT Secrets
JWT_ACCESS_SECRET=your_jwt_access_secret_key_change_me
JWT_REFRESH_SECRET=your_jwt_refresh_secret_key_change_me
JWT_ACCESS_EXPIRE=15m
JWT_REFRESH_EXPIRE=7d

# Cloudinary credentials (for incident media)
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# Google Maps API Credentials
GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# Agentic AI SOS Secret Key (used to authorize local AI models)
AI_WEBHOOK_SECRET=your_secure_ai_webhook_secret_key

# SMTP configuration for Password Reset (Mock/Real)
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USER=your_smtp_username
SMTP_PASS=your_smtp_password
FROM_EMAIL=noreply@nigehbaan.gov.pk
